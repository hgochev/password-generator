{
  "name": "password-generator-dev-container",
  "image": "mcr.microsoft.com/devcontainers/go:1.26",
  "postCreateCommand": "sudo chown -R vscode:vscode /workspaces",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ],
      "settings": {
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "go.gopath": "/go",
        "go.delveConfig": {
          "debugAdapter": "dlv-dap"
        }
      }
    }
  }
}
